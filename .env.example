# Defaults shown in the settings form (all overridable in the UI at runtime).
# WSS endpoint of the FreeSWITCH sofia profile (internal wss-binding :7443).
VITE_WSS_URL=wss://192.168.48.143:7443
# SIP domain / realm users register in.
VITE_SIP_DOMAIN=192.168.48.143
# Default extension to prefill (e.g. 4201 / 4202 / 4100).
VITE_DEFAULT_USER=4201
